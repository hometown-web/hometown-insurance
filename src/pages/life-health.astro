---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Life & Health Insurance | Hometown Insurance Agency">
    <a href="#form-bottom" class="btn btn-red btn-pulse" slot="quote-button">Get a Quote</a>

    <style>
        .hero-wrapper {
            position: relative;
            background: url('https://static-asset.amac.us/wp-content/uploads/2026/02/10122755/health.jpg') no-repeat center center;
            background-size: cover;
            padding: 80px 0 140px 0;
            color: white;
            border-bottom: 8px solid var(--primary-red);
        }
        .hero-wrapper::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(90deg, rgba(0, 0, 0, 0.95) 0%, rgba(0, 0, 0, 0.6) 40%, rgba(0, 0, 0, 0) 100%);
            z-index: 1;
        }
        .hero-grid { align-items: start; }
        .hero-content { padding-top: 20px; }
        .hero-content h1 { font-size: 62px; line-height: 1.1; margin-bottom: 25px; color: white; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
        .hero-content p { color: #f8fafc; font-size: 24px; max-width: 600px; margin-bottom: 35px; text-shadow: 0 1px 5px rgba(0,0,0,0.5); }

        .other-details-container { display: none; margin-top: 15px; }

        .content-section { padding: 100px 0; background: white; }
        .content-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 80px; align-items: start; }
        .side-image { width: 100%; height: auto; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
        .benefit-card { background: var(--bg-light); border-radius: 12px; padding: 40px; margin-bottom: 30px; border-left: 6px solid var(--primary-red); }
        .benefit-card h3 { font-size: 28px; margin-bottom: 15px; }
        .benefit-card p { color: var(--text-gray); }

        .action-divider {
            height: 500px;
            background: linear-gradient(rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.4)), url('https://static-asset.amac.us/wp-content/uploads/2026/02/11094502/worksite.jpg') no-repeat center center fixed;
            background-size: cover;
        }

        .cta-footer {
            position: relative;
            background: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.4)), url('https://static-asset.amac.us/wp-content/uploads/2026/02/10131418/healthy-food.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 100px 0;
            text-align: center;
        }
        .cta-footer .container { position: relative; z-index: 2; display: flex; justify-content: center; }
        .cta-footer .quote-card { width: 100%; max-width: 480px; }

        /* Multi-Select Styles */
        .multi-select-hint {
            font-size: 13px;
            color: #64748b;
            margin: -5px 0 8px 0;
            font-style: italic;
        }
        .multi-select-wrapper {
            position: relative;
        }
        .multi-select-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .multi-select-display:hover {
            border-color: #cbd5e1;
        }
        .multi-select-display.active {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
        }
        .multi-select-text {
            color: #64748b;
            flex-grow: 1;
        }
        .multi-select-text.has-selection {
            color: #1e293b;
        }
        .multi-select-arrow {
            color: #64748b;
            transition: transform 0.2s ease;
        }
        .multi-select-display.active .multi-select-arrow {
            transform: rotate(180deg);
        }
        .multi-select-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid var(--primary-red);
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            z-index: 1000;
            display: none;
            margin-top: 4px;
        }
        .multi-select-dropdown.show {
            display: block;
        }
        .multi-select-options {
            max-height: 240px;
            overflow-y: auto;
            padding: 8px 0;
        }
        .multi-select-option {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            cursor: pointer;
            transition: background-color 0.2s ease;
            margin: 0;
        }
        .multi-select-option:hover {
            background: #f8fafc;
        }
        .multi-select-option input[type="checkbox"] {
            margin: 0 12px 0 0;
            width: 16px;
            height: 16px;
            accent-color: var(--primary-red);
        }
        .multi-select-option span {
            color: #1e293b;
            font-weight: normal;
        }
        .multi-select-actions {
            border-top: 1px solid #e2e8f0;
            padding: 12px 16px;
            text-align: right;
        }
        .multi-select-done {
            background: var(--primary-red);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }
        .multi-select-done:hover {
            background: #dc2626;
        }

        @media (max-width: 992px) {
            .hero-grid, .content-layout { grid-template-columns: 1fr; }
            .hero-content { margin-top: 0; }
        }
    </style>

    <div class="hero-wrapper">
        <section class="container hero-grid">
            <div class="hero-content">
