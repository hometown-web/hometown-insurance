---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Personal Insurance | Hometown Insurance Agency">
    <a href="#form-bottom" class="btn btn-red btn-pulse" slot="quote-button">Get a Quote</a>

    <style>
        .hero-wrapper {
            position: relative;
            background: url('https://static-asset.amac.us/wp-content/uploads/2026/02/10124555/condo.jpg') no-repeat center center;
            background-size: cover;
            padding: 60px 0 120px 0;
            color: white;
            border-bottom: 8px solid var(--primary-red);
        }
        .hero-wrapper::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(90deg, rgba(15, 23, 42, 0.85) 20%, rgba(15, 23, 42, 0.4) 100%);
            z-index: 1;
        }
        .hero-content { margin-top: 20px; }
        .hero-content h1 { font-size: 62px; line-height: 1.1; margin-bottom: 25px; color: white; }
        .hero-content p { color: #cbd5e1; font-size: 24px; max-width: 600px; margin-bottom: 35px; }

        .coverage-section {
            padding: 80px 0 40px 0;
            background: white;
            scroll-margin-top: 170px;
        }
        .coverage-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; align-items: start; }
        .portrait-img { width: 100%; border-radius: 20px; box-shadow: 0 30px 60px -12px rgba(0,0,0,0.25); }
        .accordion { margin-top: 30px; }

        .dd-section { padding: 40px 0 80px 0; background: #ffffff; }
        .dd-card { background: #f8fafc; border-radius: 12px; padding: 40px; border-left: 6px solid var(--primary-red); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }

        .special-section { padding: 100px 0; background: var(--bg-light); }
        .benefits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 50px; }
        .special-card:hover { transform: none; border-color: #e2e8f0; }

        .cta-footer {
            position: relative;
            background: url('https://static-asset.amac.us/wp-content/uploads/2026/02/10125737/RV.jpg') no-repeat 80% center;
            background-size: cover;
            color: white;
            padding: 100px 0;
            text-align: center;
        }
        .cta-footer::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(15, 23, 42, 0.65), rgba(15, 23, 42, 0.75));
            z-index: 1;
        }
        .cta-footer .container { position: relative; z-index: 2; display: flex; justify-content: center; }
        .cta-footer .quote-card { width: 100%; max-width: 500px; }

        .other-details-container { display: none; }

        /* Multi-Select Styles */
        .multi-select-hint {
            font-size: 13px;
            color: #64748b;
            margin: -5px 0 8px 0;
            font-style: italic;
        }
        .multi-select-wrapper {
            position: relative;
        }
        .multi-select-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .multi-select-display:hover {
            border-color: #cbd5e1;
        }
        .multi-select-display.active {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
        }
        .multi-select-text {
            color: #64748b;
            flex-grow: 1;
        }
        .multi-select-text.has-selection {
            color: #1e293b;
        }
        .multi-select-arrow {
            color: #64748b;
            transition: transform 0.2s ease;
        }
        .multi-select-display.active .multi-select-arrow {
            transform: rotate(180deg);
        }
        .multi-select-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid var(--primary-red);
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            z-index: 1000;
            display: none;
            margin-top: 4px;
        }
        .multi-select-dropdown.show {
            display: block;
        }
        .multi-select-options {
            max-height: 240px;
            overflow-y: auto;
            padding: 8px 0;
        }
        .multi-select-option {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            cursor: pointer;
            transition: background-color 0.2s ease;
            margin: 0;
        }
        .multi-select-option:hover {
            background: #f8fafc;
        }
        .multi-select-option input[type="checkbox"] {
            margin: 0 12px 0 0;
            width: 16px;
            height: 16px;
            accent-color: var(--primary-red);
        }
        .multi-select-option span {
            color: #1e293b;
            font-weight: normal;
        }
        .multi-select-actions {
            border-top: 1px solid #e2e8f0;
            padding: 12px 16px;
            text-align: right;
        }
        .multi-select-done {
            background: var(--primary-red);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }
        .multi-select-done:hover {
            background: #dc2626;
        }

        @media (max-width: 992px) {
            .hero-grid, .coverage-layout { grid-template-columns: 1fr; }
            .hero-content { margin-top: 0; }
        }
    </style>

    <div class="hero-wrapper">
        <section class="container hero-grid">
            <div class="hero-content">
                <p class="hero-label" style="font-size: 20px;">
                    <i class="fa-solid fa-shield-halved" style="font-size: 28px;"></i> Comprehensive Personal Insurance
                </p>
                <h1>Protecting What Matters Most to You</h1>
                <p>From your home and auto to your family's future, Hometown Insurance Agency provides the customized coverage you need for peace of mind.</p>
                <div class="hero-btns">
                    <a href="#highlights" class="btn btn-white-outline">Explore Coverage Options</a>
                </div>
            </div>

            <div class="quote-card">
                <h3>Personal Quote Request</h3>
                <form id="personalFormTop">
                    <div class="form-group">
                        <label>Insurance Type Interested In <span class="req">*</span></label>
                        <p class="multi-select-hint">Click all that apply</p>
                        <div class="multi-select-wrapper">
                            <div class="multi-select-display" onclick="toggleMultiSelect('insurance_type_top')">
                                <span class="multi-select-text">Select insurance types...</span>
                                <i class="fas fa-chevron-down multi-select-arrow"></i>
                            </div>
                            <div class="multi-select-dropdown" id="insurance_type_top_dropdown">
                                <div class="multi-select-options">
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Auto Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Auto Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Homeowners Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Homeowners Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Condo/Renters Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Condo/Renters Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Umbrella Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Umbrella Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Boat & Yacht Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Boat & Yacht Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Flood Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Flood Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Valuables/Collectibles" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Valuables/Collectibles</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Classic Car Insurance" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Classic Car Insurance</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="RV & Recreational" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>RV & Recreational</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Other" onchange="updateMultiSelectDisplay('insurance_type_top')">
                                        <span>Other</span>
                                    </label>
                                </div>
                                <div class="multi-select-actions">
                                    <button type="button" class="multi-select-done" onclick="closeMultiSelect('insurance_type_top')">Done</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group"><label>Full Name <span class="req">*</span></label><input type="text" name="full_name" placeholder="Your Name" required></div>
                    <div class="form-group"><label>Email Address <span class="req">*</span></label><input type="email" name="email" placeholder="email@address.com" required></div>
                    <div class="form-group"><label>Leave a message (optional)</label><textarea name="message" rows="2" placeholder="Tell us more..."></textarea></div>
                    <div class="form-group">
                        <label>How should we contact you?</label>
                        <div class="radio-inline-container">
                            <label><input type="radio" name="contact_method" value="email" checked onchange="toggleCallback('top', false)"> Email</label>
                            <label><input type="radio" name="contact_method" value="phone" onchange="toggleCallback('top', true)"> Callback</label>
                        </div>
                    </div>
                    <div id="callback_fields_top" class="callback-fields">
                        <div class="form-group"><label>Phone Number <span class="req">*</span></label><input type="tel" name="phone"></div>
                        <div class="form-group"><label>Best Day & Time <span class="req">*</span></label><input type="text" name="callback_time" placeholder="e.g. Monday Morning"></div>
                    </div>
                    <div class="form-group">
                        <label>How did you hear about us? <span class="req">*</span></label>
                        <p class="multi-select-hint">Click all that apply</p>
                        <div class="multi-select-wrapper">
                            <div class="multi-select-display" onclick="toggleMultiSelect('hear_about_top')">
                                <span class="multi-select-text">Please select...</span>
                                <i class="fas fa-chevron-down multi-select-arrow"></i>
                            </div>
                            <div class="multi-select-dropdown" id="hear_about_top_dropdown">
                                <div class="multi-select-options">
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Google Search" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Google Search</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Facebook / Instagram" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Facebook / Instagram</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Friend or Family Member" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Friend or Family Member</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Mailing / Flyer" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Mailing / Flyer</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Local Event" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Local Event</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Other" onchange="updateMultiSelectDisplay('hear_about_top')">
                                        <span>Other</span>
                                    </label>
                                </div>
                                <div class="multi-select-actions">
                                    <button type="button" class="multi-select-done" onclick="closeMultiSelect('hear_about_top')">Done</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-red" style="width: 100%; margin-top: 10px;">Send Request</button>
                </form>
                <p id="personalFormTopMsg" style="display:none; margin-top:10px; font-weight:700;"></p>
            </div>
        </section>
    </div>

    <section id="highlights" class="container coverage-section">
        <div class="coverage-layout">
            <div class="portrait-frame">
                <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/10124929/family.jpg" alt="Happy Family" class="portrait-img">
            </div>
            <div>
                <h2 style="font-size: 40px; margin-bottom: 20px;">Personal Coverage Highlights</h2>
                <p>We offer a broad range of products to meet your unique lifestyle and protection needs.</p>

                <div class="accordion">
                    <div class="accordion-item active">
                        <div class="accordion-header" onclick="toggleAccordion(this)"><h3>Home & Property</h3><i class="fa-solid fa-chevron-down"></i></div>
                        <div class="accordion-content">
                            <ul class="coverage-list">
                                <li>Homeowners Insurance (Replacement Cost)</li>
                                <li>Condo & Co-op Owner Policies</li>
                                <li>Renters Insurance for Personal Belongings</li>
                                <li>Flood Insurance (Even for non-waterfront)</li>
                                <li>Valuable Articles (Jewelry, Fine Arts, Antiques)</li>
                            </ul>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <div class="accordion-header" onclick="toggleAccordion(this)"><h3>Auto & Vehicle</h3><i class="fa-solid fa-chevron-down"></i></div>
                        <div class="accordion-content">
                            <ul class="coverage-list">
                                <li>Standard Auto Insurance</li>
                                <li>Classic & Collector Car Coverage</li>
                                <li>Motorcycles & ATVs</li>
                                <li>Recreational Vehicles (Winnebago, etc.)</li>
                                <li>Boat & Yacht Insurance</li>
                            </ul>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <div class="accordion-header" onclick="toggleAccordion(this)"><h3>Liability & Life</h3><i class="fa-solid fa-chevron-down"></i></div>
                        <div class="accordion-content">
                            <ul class="coverage-list">
                                <li>Personal Umbrella Liability (Excess Coverage)</li>
                                <li>Individual Life Insurance</li>
                                <li>Health Insurance Solutions</li>
                                <li>Long-Term Care Planning</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dd-section">
        <div class="container">
            <div style="text-align: center; margin-bottom: 40px;">
                <h2 style="font-size: 44px;">Defensive Driving Resources</h2>
                <p style="color: var(--text-gray);">Enhance your safety and lower your insurance costs.</p>
            </div>
            <div class="dd-card">
                <div style="display: flex; align-items: flex-start; gap: 25px;">
                    <i class="fa-solid fa-car-side" style="font-size: 48px; color: var(--primary-red); margin-top: 5px;"></i>
                    <div>
                        <p style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--primary-red); margin-bottom: 8px;">Approved by the New York State Department of Motor Vehicles</p>
                        <h3 style="font-size: 26px; margin-bottom: 15px;">Defensive Driving Online Course</h3>
                        <p style="font-size: 18px; margin-bottom: 20px;">
                            Take the official online course via the
                            <a href="https://empiresafetycouncil.com/" target="_blank" style="color: var(--primary-red); font-weight: 700; text-decoration: underline;">Empire Safety Council</a>.
                        </p>
                        <div style="background: var(--white); display: inline-block; padding: 15px 25px; border: 2px dashed var(--primary-red); border-radius: 8px; margin-bottom: 25px;">
                            <span style="font-size: 18px; font-weight: 700; color: var(--dark-blue);">
                                USE PROMO CODE: <span style="color: var(--primary-red);">HOMETOWN</span> — To receive the Lowest inclusive price of $34.95
                            </span>
                        </div>
                        <p style="font-size: 16px; color: var(--text-gray); border-top: 1px solid #e2e8f0; margin-top: 10px; padding-top: 20px;">
                            If you would like information about the online Defensive Driving course, please contact us by email
                            <a href="mailto:service@hometowninsurance.com" style="color: var(--primary-red); font-weight: 600;">service@hometowninsurance.com</a>
                            or call <a href="tel:6315890100" style="color: var(--primary-red); font-weight: 600;">631-589-0100</a>.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="special-section">
        <div class="container">
            <div style="text-align: center; margin-bottom: 20px;">
                <h2 style="font-size: 44px;">Personal Insurance Portfolio</h2>
                <p style="color: var(--text-gray);">Comprehensive solutions for your assets and loved ones.</p>
            </div>

            <div class="benefits-grid">
                <div class="special-card">
                    <i class="fa-solid fa-car"></i>
                    <div>
                        <h3>Auto Insurance</h3>
                        <p>Protect your vehicle with dependable auto insurance coverage for liability, collision, and comprehensive protection—so you can drive with confidence.</p>
                    </div>
                </div>
                <div class="special-card">
                    <i class="fa-solid fa-house-chimney"></i>
                    <div>
                        <h3>Homeowners Insurance</h3>
                        <p>Your home is one of your most valuable assets. Homeowners insurance helps protect your property, belongings, and personal liability from unexpected events.</p>
                    </div>
                </div>
                <div class="special-card">
                    <i class="fa-solid fa-umbrella"></i>
                    <div>
                        <h3>Umbrella Insurance</h3>
                        <p>Add an extra layer of protection with umbrella liability insurance, extending coverage beyond the limits of your home and auto policies.</p>
                    </div>
                </div>
                <div class="special-card">
                    <i class="fa-solid fa-ship"></i>
                    <div>
                        <h3>Boat & Yacht Insurance</h3>
                        <p>Enjoy the water with confidence with boat and yacht insurance designed to protect your vessel, equipment, and liability exposures.</p>
                    </div>
                </div>
                <div class="special-card">
                    <i class="fa-solid fa-gem"></i>
                    <div>
                        <h3>Valuable Items Insurance</h3>
                        <p>Safeguard jewelry, collectibles, antiques, and other prized possessions with valuable items insurance designed for high-value belongings.</p>
                    </div>
                </div>
                <div class="special-card">
                    <i class="fa-solid fa-heart-pulse"></i>
                    <div>
                        <h3>Life & Health Insurance</h3>
                        <p>Secure your family's future with life and health insurance solutions that provide financial protection and peace of mind.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="cta-footer" id="form-bottom">
        <div class="container">
            <div class="quote-card" style="max-width: 600px; margin: 0 auto; text-align: left;">
                <h3>Personal Quote Request</h3>
                <form id="personalFormBottom">
                    <div class="form-group">
                        <label>What coverage do you need? <span class="req">*</span></label>
                        <p class="multi-select-hint">Click all that apply</p>
                        <div class="multi-select-wrapper">
                            <div class="multi-select-display" onclick="toggleMultiSelect('insurance_type_bottom')">
                                <span class="multi-select-text">Select coverage types...</span>
                                <i class="fas fa-chevron-down multi-select-arrow"></i>
                            </div>
                            <div class="multi-select-dropdown" id="insurance_type_bottom_dropdown">
                                <div class="multi-select-options">
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Auto & Homeowners Bundle" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Auto & Homeowners Bundle</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Individual Homeowners" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Individual Homeowners</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Individual Auto" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Individual Auto</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Umbrella/Liability" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Umbrella/Liability</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Recreational/Marine" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Recreational/Marine</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Life/Health" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Life/Health</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="insurance_type[]" value="Other" onchange="updateMultiSelectDisplay('insurance_type_bottom')">
                                        <span>Other</span>
                                    </label>
                                </div>
                                <div class="multi-select-actions">
                                    <button type="button" class="multi-select-done" onclick="closeMultiSelect('insurance_type_bottom')">Done</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group"><label>Your Full Name <span class="req">*</span></label><input type="text" name="full_name" placeholder="Full Name" required></div>
                    <div class="form-group"><label>Email Address <span class="req">*</span></label><input type="email" name="email" placeholder="email@address.com" required></div>
                    <div class="form-group"><label>Leave a message (optional)</label><textarea name="message" rows="2" placeholder="Tell us more..."></textarea></div>
                    <div class="form-group">
                        <label>How should we contact you?</label>
                        <div class="radio-inline-container">
                            <label><input type="radio" name="contact_method" value="email" checked onchange="toggleCallback('bot', false)"> Email</label>
                            <label><input type="radio" name="contact_method" value="phone" onchange="toggleCallback('bot', true)"> Callback</label>
                        </div>
                    </div>
                    <div id="callback_fields_bot" class="callback-fields">
                        <div class="form-group"><label>Phone Number <span class="req">*</span></label><input type="tel" name="phone"></div>
                        <div class="form-group"><label>Best Day & Time <span class="req">*</span></label><input type="text" name="callback_time" placeholder="e.g. Wednesday Mornings"></div>
                    </div>
                    <div class="form-group">
                        <label>How did you hear about us? <span class="req">*</span></label>
                        <p class="multi-select-hint">Click all that apply</p>
                        <div class="multi-select-wrapper">
                            <div class="multi-select-display" onclick="toggleMultiSelect('hear_about_bottom')">
                                <span class="multi-select-text">Please select...</span>
                                <i class="fas fa-chevron-down multi-select-arrow"></i>
                            </div>
                            <div class="multi-select-dropdown" id="hear_about_bottom_dropdown">
                                <div class="multi-select-options">
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Google Search" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Google Search</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Facebook / Instagram" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Facebook / Instagram</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Friend or Family Member" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Friend or Family Member</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Mailing / Flyer" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Mailing / Flyer</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Local Event" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Local Event</span>
                                    </label>
                                    <label class="multi-select-option">
                                        <input type="checkbox" name="hear_about[]" value="Other" onchange="updateMultiSelectDisplay('hear_about_bottom')">
                                        <span>Other</span>
                                    </label>
                                </div>
                                <div class="multi-select-actions">
                                    <button type="button" class="multi-select-done" onclick="closeMultiSelect('hear_about_bottom')">Done</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-red" style="width: 100%; margin-top: 10px;">Send Request</button>
                </form>
                <p id="personalFormBottomMsg" style="display:none; margin-top:10px; font-weight:700;"></p>
            </div>
        </div>
    </div>

    <script is:inline>
        // Multi-Select Functions
        function toggleMultiSelect(fieldId) {
            var dropdown = document.getElementById(fieldId + '_dropdown');
            var display = dropdown.parentElement.querySelector('.multi-select-display');
            var isOpen = dropdown.classList.contains('show');
            
            // Close all other dropdowns
            document.querySelectorAll('.multi-select-dropdown').forEach(function(el) {
                el.classList.remove('show');
            });
            document.querySelectorAll('.multi-select-display').forEach(function(el) {
                el.classList.remove('active');
            });
            
            if (!isOpen) {
                dropdown.classList.add('show');
                display.classList.add('active');
            }
        }
        
        function closeMultiSelect(fieldId) {
            var dropdown = document.getElementById(fieldId + '_dropdown');
            var display = dropdown.parentElement.querySelector('.multi-select-display');
            dropdown.classList.remove('show');
            display.classList.remove('active');
        }
        
        function updateMultiSelectDisplay(fieldId) {
            var wrapper = document.getElementById(fieldId + '_dropdown').parentElement;
            var textElement = wrapper.querySelector('.multi-select-text');
            var checkboxes = wrapper.querySelectorAll('input[type="checkbox"]:checked');
            
            if (checkboxes.length === 0) {
                textElement.textContent = fieldId.includes('insurance_type') ? 
                    (fieldId.includes('top') ? 'Select insurance types...' : 'Select coverage types...') : 
                    'Please select...';
                textElement.classList.remove('has-selection');
            } else if (checkboxes.length === 1) {
                textElement.textContent = checkboxes[0].nextElementSibling.textContent;
                textElement.classList.add('has-selection');
            } else {
                textElement.textContent = checkboxes.length + ' items selected';
                textElement.classList.add('has-selection');
            }
        }
        

        
        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.multi-select-wrapper')) {
                document.querySelectorAll('.multi-select-dropdown').forEach(function(el) {
                    el.classList.remove('show');
                });
                document.querySelectorAll('.multi-select-display').forEach(function(el) {
                    el.classList.remove('active');
                });
            }
        });

        function toggleCallback(prefix, show) {
            document.getElementById('callback_fields_' + prefix).style.display = show ? 'block' : 'none';
        }

        function toggleOtherField(selectElement, fieldId) {
            var otherField = document.getElementById(fieldId);
            var input = otherField.querySelector('input');
            if (selectElement.value === 'Other') {
                otherField.style.display = 'block';
                if (input) input.setAttribute('required', 'required');
            } else {
                otherField.style.display = 'none';
                if (input) { input.removeAttribute('required'); input.value = ''; }
            }
        }

        function toggleHearOther(selectElement, fieldId) {
            var container = document.getElementById(fieldId);
            var input = container.querySelector('input');
            if (selectElement.value === 'Other') {
                container.style.display = 'block';
                input.setAttribute('required', 'required');
            } else {
                container.style.display = 'none';
                input.removeAttribute('required');
                input.value = '';
            }
        }

        function toggleAccordion(header) {
            var item = header.parentElement;
            var wasActive = item.classList.contains('active');
            document.querySelectorAll('.accordion-item').forEach(function(el) { el.classList.remove('active'); });
            if (!wasActive) item.classList.add('active');
        }

        function handlePersonalFormSubmit(formId, msgId, position) {
            var form = document.getElementById(formId);
            var msg = document.getElementById(msgId);
            
            if (form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    
                    console.log('Form submit event triggered');



                    var submitBtn = form.querySelector('button[type="submit"]');
                    var originalBtnText = submitBtn.textContent;

                    // Show sending state
                    submitBtn.textContent = 'Sending...';
                    submitBtn.disabled = true;
                    msg.style.display = 'none';

                    try {
                        // Collect form data
                        var insuranceTypes = [];
                        form.querySelectorAll('input[name="insurance_type[]"]:checked').forEach(function(cb) {
                            insuranceTypes.push(cb.value);
                        });
                        
                        var hearAbout = [];
                        form.querySelectorAll('input[name="hear_about[]"]:checked').forEach(function(cb) {
                            hearAbout.push(cb.value);
                        });
                        
                        var contactMethodEl = form.querySelector('input[name="contact_method"]:checked');
                        var contactMethod = contactMethodEl ? contactMethodEl.value : 'Email';
                        
                        // Custom validation for callback fields
                        if (contactMethod === 'Callback') {
                            var phoneInput = form.querySelector('input[name="phone"]');
                            var callbackTimeInput = form.querySelector('input[name="callback_time"]');
                            
                            if (!phoneInput || !phoneInput.value.trim()) {
                                msg.style.color = '#ef4444';
                                msg.textContent = 'Please enter your phone number for callback.';
                                msg.style.display = 'block';
                                return;
                            }
                            
                            if (!callbackTimeInput || !callbackTimeInput.value.trim()) {
                                msg.style.color = '#ef4444';
                                msg.textContent = 'Please specify your preferred callback time.';
                                msg.style.display = 'block';
                                return;
                            }
                        }
                        
                        var formData = {
                            insurance_type: insuranceTypes.join(', '),
                            full_name: form.querySelector('input[name="full_name"]').value,
                            email: form.querySelector('input[name="email"]').value,
                            message: form.querySelector('textarea[name="message"]').value,
                            contact_method: contactMethod,
                            phone: form.querySelector('input[name="phone"]') ? form.querySelector('input[name="phone"]').value : '',
                            callback_time: form.querySelector('input[name="callback_time"]') ? form.querySelector('input[name="callback_time"]').value : '',
                            hear_about: hearAbout.join(', '),
                            page: 'personal',
                            form_position: position
                        };
                        
                    } catch (error) {
                        console.error('Error collecting form data:', error);
                        msg.style.color = '#ef4444';
                        msg.textContent = 'Form error: ' + error.message;
                        msg.style.display = 'block';
                        return;
                    }

                    // Debug: Log form data
                    console.log('Submitting form data:', formData);
                    
                    // Submit to API
                    fetch('/api/lead', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    })
                    .then(function(response) { 
                        console.log('API Response status:', response.status);
                        return response.json(); 
                    })
                    .then(function(data) {
                        console.log('API Response data:', data);
                        if (data.success) {
                            msg.style.color = '#10b981';
                            msg.textContent = '✓ Your request has been sent! Our team will be in touch shortly.';
                            msg.style.display = 'block';
                            form.reset();
                            
                            // Reset multi-select displays
                            form.querySelectorAll('.multi-select-text').forEach(function(text) {
                                if (text.textContent.includes('insurance')) {
                                    text.textContent = 'Select insurance types...';
                                } else {
                                    text.textContent = 'Please select...';
                                }
                                text.classList.remove('has-selection');
                            });
                        } else {
                            msg.style.color = '#ef4444';
                            msg.textContent = data.error || 'Something went wrong. Please try again.';
                            msg.style.display = 'block';
                        }
                    })
                    .catch(function(error) {
                        console.error('Network/API error:', error);
                        msg.style.color = '#ef4444';
                        msg.textContent = 'Network error: ' + error.message;
                        msg.style.display = 'block';
                    })
                    .finally(function() {
                        submitBtn.textContent = originalBtnText;
                        submitBtn.disabled = false;
                    });
                });
            }
        }

        
        handlePersonalFormSubmit('personalFormTop', 'personalFormTopMsg', 'top');
        handlePersonalFormSubmit('personalFormBottom', 'personalFormBottomMsg', 'bottom');
    </script>
</BaseLayout>
