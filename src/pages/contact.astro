---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us | Hometown Insurance Agency">

    <section class="contact-hero">
        <div class="container">
            <h1>We're Here to Help</h1>
            <p>At Hometown Insurance, you're more than a policy number. Our licensed insurance professionals provide clear guidance and dependable coverage solutions to help protect what matters most. We assist individuals, families, and businesses with <b>insurance</b> tailored to their needs.</p>
        </div>
    </section>

    <main class="container">
        <div class="contact-grid">
            <div class="info-section">
                <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/10130312/orville.jpg" alt="Hometown Insurance Office Exterior" class="office-img">

                <h2>Visit Our Local Office</h2>
                <div class="contact-details">
                    <div class="detail-item">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <div>
                            <h4>Address</h4>
                            <p><a href="#contact-map" onclick="event.preventDefault(); document.getElementById('contact-map').scrollIntoView({ behavior: 'smooth', block: 'start' });" style="color: inherit; text-decoration: none; cursor: pointer;">5 Orville Drive, Suite 400<br>Bohemia, NY 11716</a></p>
                        </div>
                    </div>
                    <div class="detail-item">
                        <i class="fa-solid fa-clock"></i>
                        <div>
                            <h4>Office Hours</h4>
                            <p>Monday - Friday: 9:00 AM - 5:00 PM<br>Saturday & Sunday: Closed</p>

                            <div style="margin-top: 15px; padding: 15px; background: #fff5f5; border-left: 4px solid var(--primary-red); border-radius: 4px; display: flex; align-items: center; gap: 12px;">
                                <i class="fa-solid fa-calendar-check" style="color: var(--primary-red); font-size: 20px; margin-top: 0;"></i>
                                <p style="font-size: 16px; line-height: 1.4; color: var(--dark-blue); font-weight: 600;">
                                    We can accommodate appointments after hours <a href="tel:6315890100" style="color: var(--primary-red); text-decoration: underline;">Call us to schedule</a>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <i class="fa-solid fa-phone"></i>
                        <div>
                            <h4>Phone & Fax</h4>
                            <p>Phone: <a href="tel:6315890100" style="color: inherit; text-decoration: none;">631-589-0100</a><br>Fax: <a href="tel:6315894921" style="color: inherit; text-decoration: none;">631-589-4921</a></p>
                        </div>
                    </div>
                    <div class="detail-item">
                        <i class="fa-solid fa-envelope"></i>
                        <div>
                            <h4>Email</h4>
                            <p><a href="mailto:service@hometowninsurance.com" style="color: var(--primary-red); text-decoration: none;">service@hometowninsurance.com</a></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 style="margin-bottom: 10px; font-size: 32px;">Personalized Insurance Support</h3>
                <p style="margin-bottom: 25px; color: var(--text-gray); font-size: 18px; line-height: 1.6;">Whether you need help reviewing an existing policy, requesting a quote for your home, auto or business coverage, or exploring multiple companies, our team is here to assist. Call <a href="tel:6315890100" style="color: inherit; text-decoration: underline;">631-589-0100</a>, email us, or visit our office in <b>Bohemia</b>. We proudly serve clients throughout <b>Long Island</b>, across <b>New York</b>, and are licensed to serve clients in <b>46 states nationwide</b>.</p>

                <div class="contact-card">
                    <h2 style="margin-bottom: 10px; font-size: 32px;">Contact an Agent</h2>
                    <p style="margin-bottom: 30px; color: var(--text-gray);">Have a question about <b>auto insurance, homeowners insurance, business insurance, or specialty coverage</b>? Drop us a line below. One of our experienced team members will review your message and respond promptly with the information, guidance, and coverage options you need.</p>

                    <form id="contactForm">
                        <div class="form-row">
                            <div class="form-group">
                                <label>First Name <span class="req">*</span></label>
                                <input type="text" name="first_name" placeholder="John" required>
                            </div>
                            <div class="form-group">
                                <label>Last Name <span class="req">*</span></label>
                                <input type="text" name="last_name" placeholder="Doe" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Email Address <span class="req">*</span></label>
                                <input type="email" name="email" placeholder="john.doe@email.com" required>
                            </div>
                            <div class="form-group">
                                <label>Phone Number <span class="req">*</span></label>
                                <input type="tel" name="phone" placeholder="(555) 555-5555" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>How can we help? <span class="req">*</span></label>
                            <p class="multi-select-hint">Click all that apply</p>
                            <div class="multi-select-wrapper">
                                <div class="multi-select-display" onclick="toggleMultiSelect('help_type')">
                                    <span class="multi-select-text">Please select...</span>
                                    <i class="fas fa-chevron-down multi-select-arrow"></i>
                                </div>
                                <div class="multi-select-dropdown" id="help_type_dropdown">
                                    <div class="multi-select-options">
                                        <label class="multi-select-option">
                                            <input type="checkbox" name="help_type[]" value="I'd like a quick quote" onchange="updateMultiSelectDisplay('help_type')">
                                            <span>I'd like a quick quote</span>
                                        </label>
                                        <label class="multi-select-option">
                                            <input type="checkbox" name="help_type[]" value="I have a question about my policy" onchange="updateMultiSelectDisplay('help_type')">
                                            <span>I have a question about my policy</span>
                                        </label>
                                        <label class="multi-select-option">
                                            <input type="checkbox" name="help_type[]" value="I need help with a claim" onchange="updateMultiSelectDisplay('help_type')">
                                            <span>I need help with a claim</span>
                                        </label>
                                        <label class="multi-select-option">
                                            <input type="checkbox" name="help_type[]" value="General Inquiry" onchange="updateMultiSelectDisplay('help_type')">
                                            <span>General Inquiry</span>
                                        </label>
                                    </div>
                                    <div class="multi-select-actions">
                                        <button type="button" class="multi-select-done" onclick="closeMultiSelect('help_type')">Done</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Your Message (Optional)</label>
                            <textarea name="message" placeholder="Tell us a little bit about what you're looking for..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-red" style="width: 100%;">Send Message</button>
                    </form>
                    <p id="contactFormMsg" style="display:none; margin-top:10px; font-weight:700;"></p>
                </div>
            </div>
        </div>
    </main>

    <section class="full-width-map" id="contact-map" style="scroll-margin-top: 180px;">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.731420790479!2d-73.12053672342548!3d40.78010377138332!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e83693f9c62371%3A0xc3f173b2a2656910!2s5%20Orville%20Dr%2C%20Bohemia%2C%20NY%2011716!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </section>

    <section class="personal-insurance-selector">
        <div class="container">
            <h2 style="font-size: 28px;">Personal Insurance Information</h2>
            <p>Choose a category below to learn more about our specific personal coverage options.</p>

            <div class="selector-grid">
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-car"></i>
                    <h3>Auto Insurance</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-house"></i>
                    <h3>Homeowners</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-umbrella"></i>
                    <h3>Umbrella Policy</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-ship"></i>
                    <h3>Boat & Watercraft</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-motorcycle"></i>
                    <h3>Motorcycle</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-shield-heart"></i>
                    <h3>Life Insurance</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-gauge-high"></i>
                    <h3>Classic Car</h3>
                </a>
                <a href="/personal" class="insurance-box">
                    <i class="fa-solid fa-house-flood-water"></i>
                    <h3>Flood Insurance</h3>
                </a>
            </div>
        </div>
    </section>

    <style>
        .contact-hero {
            position: relative;
            background: url('https://static-asset.amac.us/wp-content/uploads/2026/02/10110749/call-center.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 90px 0;
            text-align: center;
            border-bottom: none;
        }
        .contact-hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.75);
            z-index: 1;
        }
        .contact-hero .container { position: relative; z-index: 2; }
        .contact-hero h1 { color: white; font-size: 56px; margin-bottom: 15px; }
        .contact-hero p { font-size: 22px; max-width: 850px; margin: 0 auto; line-height: 1.6; }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 60px;
            padding: 80px 0;
        }

        .contact-card {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
        }
        .contact-card .form-group input,
        .contact-card .form-group textarea,
        .contact-card .form-group select {
            width: 100%; padding: 14px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 16px;
        }
        .contact-card .form-group textarea { height: 120px; resize: vertical; }

        .info-section h2 { font-size: 32px; margin-bottom: 25px; }
        .contact-details { margin-bottom: 40px; }
        .detail-item { display: flex; gap: 20px; margin-bottom: 25px; }
        .detail-item > i { color: var(--primary-red); font-size: 24px; margin-top: 5px; }
        .detail-item h4 { font-size: 20px; margin-bottom: 5px; }

        .full-width-map {
            width: 100%;
            height: 450px;
            border-top: 1px solid #e5e7eb;
            border-bottom: 1px solid #e5e7eb;
            display: block;
        }

        .personal-insurance-selector {
            background: var(--bg-light);
            padding: 80px 0;
            text-align: center;
        }
        .selector-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        .insurance-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: inherit;
        }
        .insurance-box:hover {
            border-color: var(--primary-red);
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }
        .insurance-box i { font-size: 40px; color: var(--primary-red); margin-bottom: 15px; }
        .insurance-box h3 { font-size: 20px; }

        .office-img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* Multi-Select Styles */
        .multi-select-hint {
            font-size: 13px;
            color: #64748b;
            margin: -5px 0 8px 0;
            font-style: italic;
        }
        .multi-select-wrapper {
            position: relative;
        }
        .multi-select-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .multi-select-display:hover {
            border-color: #cbd5e1;
        }
        .multi-select-display.active {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
        }
        .multi-select-text {
            color: #64748b;
            flex-grow: 1;
        }
        .multi-select-text.has-selection {
            color: #1e293b;
        }
        .multi-select-arrow {
            color: #64748b;
            transition: transform 0.2s ease;
        }
        .multi-select-display.active .multi-select-arrow {
            transform: rotate(180deg);
        }
        .multi-select-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid var(--primary-red);
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            z-index: 1000;
            display: none;
            margin-top: 4px;
        }
        .multi-select-dropdown.show {
            display: block;
        }
        .multi-select-options {
            max-height: 240px;
            overflow-y: auto;
            padding: 8px 0;
        }
        .multi-select-option {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            cursor: pointer;
            transition: background-color 0.2s ease;
            margin: 0;
        }
        .multi-select-option:hover {
            background: #f8fafc;
        }
        .multi-select-option input[type="checkbox"] {
            margin: 0 12px 0 0;
            width: 16px;
            height: 16px;
            accent-color: var(--primary-red);
        }
        .multi-select-option span {
            color: #1e293b;
            font-weight: normal;
        }
        .multi-select-actions {
            border-top: 1px solid #e2e8f0;
            padding: 12px 16px;
            text-align: right;
        }
        .multi-select-done {
            background: var(--primary-red);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }
        .multi-select-done:hover {
            background: #dc2626;
        }

        @media (max-width: 992px) {
            .contact-grid { grid-template-columns: 1fr; }
        }
    </style>

    <script is:inline>
        // Multi-Select Functions
        function toggleMultiSelect(fieldId) {
            var dropdown = document.getElementById(fieldId + '_dropdown');
            var display = dropdown.parentElement.querySelector('.multi-select-display');
            var isOpen = dropdown.classList.contains('show');
            
            // Close all other dropdowns
            document.querySelectorAll('.multi-select-dropdown').forEach(function(el) {
                el.classList.remove('show');
            });
            document.querySelectorAll('.multi-select-display').forEach(function(el) {
                el.classList.remove('active');
            });
            
            if (!isOpen) {
                dropdown.classList.add('show');
                display.classList.add('active');
            }
        }
        
        function closeMultiSelect(fieldId) {
            var dropdown = document.getElementById(fieldId + '_dropdown');
            var display = dropdown.parentElement.querySelector('.multi-select-display');
            dropdown.classList.remove('show');
            display.classList.remove('active');
        }
        
        function updateMultiSelectDisplay(fieldId) {
            var wrapper = document.getElementById(fieldId + '_dropdown').parentElement;
            var textElement = wrapper.querySelector('.multi-select-text');
            var checkboxes = wrapper.querySelectorAll('input[type="checkbox"]:checked');
            
            if (checkboxes.length === 0) {
                textElement.textContent = 'Please select...';
                textElement.classList.remove('has-selection');
            } else if (checkboxes.length === 1) {
                textElement.textContent = checkboxes[0].nextElementSibling.textContent;
                textElement.classList.add('has-selection');
            } else {
                textElement.textContent = checkboxes.length + ' items selected';
                textElement.classList.add('has-selection');
            }
        }
        
        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.multi-select-wrapper')) {
                document.querySelectorAll('.multi-select-dropdown').forEach(function(el) {
                    el.classList.remove('show');
                });
                document.querySelectorAll('.multi-select-display').forEach(function(el) {
                    el.classList.remove('active');
                });
            }
        });

        var contactForm = document.getElementById('contactForm');
        var contactFormMsg = document.getElementById('contactFormMsg');

        if (contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault();

                var submitBtn = contactForm.querySelector('button[type="submit"]');
                var originalBtnText = submitBtn.textContent;

                submitBtn.textContent = 'Sending...';
                submitBtn.disabled = true;
                if (contactFormMsg) contactFormMsg.style.display = 'none';

                var helpTypes = [];
                contactForm.querySelectorAll('input[name="help_type[]"]:checked').forEach(function(cb) {
                    helpTypes.push(cb.value);
                });

                var formData = {
                    first_name: contactForm.querySelector('input[name="first_name"]').value,
                    last_name: contactForm.querySelector('input[name="last_name"]').value,
                    email: contactForm.querySelector('input[name="email"]').value,
                    phone: contactForm.querySelector('input[name="phone"]').value,
                    help_type: helpTypes.join(', '),
                    message: contactForm.querySelector('textarea[name="message"]').value,
                    page: 'contact'
                };

                fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        contactFormMsg.style.color = '#10b981';
                        contactFormMsg.textContent = '✓ Your message has been sent! Our team will be in touch shortly.';
                        contactFormMsg.style.display = 'block';
                        contactForm.reset();
                    } else {
                        contactFormMsg.style.color = '#ef4444';
                        contactFormMsg.textContent = data.error || 'Something went wrong. Please try again.';
                        contactFormMsg.style.display = 'block';
                    }
                })
                .catch(function() {
                    contactFormMsg.style.color = '#ef4444';
                    contactFormMsg.textContent = 'Network error. Please try again.';
                    contactFormMsg.style.display = 'block';
                })
                .finally(function() {
                    submitBtn.textContent = originalBtnText;
                    submitBtn.disabled = false;
                });
            });
        }
    </script>

</BaseLayout>
