---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Report a Claim | Hometown Insurance Agency">

    <section class="claims-hero">
        <div class="container">
            <h1>Report a Claim</h1>
            <p style="line-height: 1.3; margin-bottom: 25px;">If you've experienced a loss related to your home insurance, auto insurance, or business insurance policy, please notify your insurance company as soon as possible.</p>
            <p>Start typing your Insurance company name below.</p>

            <div class="search-container">
                <input type="text" id="carrierSearch" placeholder="Enter Company Name (e.g. Progressive, Travelers)..." autocomplete="off">
                <span id="clearSearch"><i class="fa-solid fa-circle-xmark"></i></span>
                <div id="autocompleteList" class="autocomplete-results"></div>
            </div>
        </div>
    </section>

    <div class="claims-main">
        <div class="container">

            <div id="result-card">
                <span class="close-card" onclick="closeResultCard()"><i class="fa-solid fa-xmark"></i></span>
                <h2 id="res-name" class="carrier-title">Company Name</h2>
                <div id="details-container"></div>
                <button onclick="window.print()" class="btn btn-white btn-print" style="width: 100%; margin-top: 20px;">
                    <i class="fa-solid fa-print"></i> Print This Information
                </button>
            </div>

            <div class="manual-browse">
                <div class="section-title-wrap">
                    <h2>Hometown Insurance Carriers</h2>
                </div>

                <span class="instruction-text">Click the bar below to view the checklist before calling</span>
                <div class="emergency-accordion">
                    <div class="accordion-header" onclick="toggleAccordion()"
                        <span><i class="fa-solid fa-clipboard-list" style="color: var(--primary-red); margin-right: 10px;"></i> Claims Reporting Checklist</span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                    <div class="accordion-content" id="accordionContent">
                        <p style="margin-bottom: 15px;">Have your policy number and key details ready, including the date, description, location, police report number, and any witness information. Please have the following information ready:</p>

                        <div class="checklist-grid">
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Policy Number</div>
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Date of Loss</div>
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Description of Loss</div>
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Loss Location</div>
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Police Report Numbers</div>
                            <div class="checklist-item"><i class="fa-solid fa-check-circle"></i> Witness Information</div>
                        </div>

                        <p style="margin-top: 20px; font-style: italic; border-top: 1px solid #eee; padding-top: 15px;">If you need assistance or if you do not see your insurance company listed below, feel free to contact your Hometown Insurance Agency of LI Agent.</p>
                    </div>
                </div>

                <div class="office-hours-notice">
                    <i class="fa-solid fa-clock" style="margin-right: 8px;"></i>
                    If you need assistance contact your Hometown Account Representative between <br> <strong>9:00 AM – 5:00 PM (Mon-Fri) ET</strong> at <strong>631-589-0100</strong>.
                </div>

                <div class="carrier-grid" id="mainGrid"></div>
            </div>
        </div>
    </div>

    <style is:global>
        .claims-hero {
            position: relative;
            background: url('https://static-asset.amac.us/wp-content/uploads/2026/02/26095305/call-center-1.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 30px 0;
            text-align: center;
        }
        .claims-hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.6) 100%);
            z-index: 1;
        }
        .claims-hero .container { position: relative; z-index: 2; }
        .claims-hero h1 { color: white; font-size: 48px; margin-bottom: 15px; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
        .claims-hero p { font-size: 20px; max-width: 800px; margin: 0 auto 30px; opacity: 1; text-shadow: 0 2px 8px rgba(0,0,0,0.8); }

        #clearSearch {
            position: absolute; right: 25px; top: 50%; transform: translateY(-50%);
            font-size: 20px; color: #94a3b8; cursor: pointer; display: none; transition: 0.2s;
            z-index: 2001;
        }
        #clearSearch:hover { color: var(--primary-red); }

        .claims-main { padding: 60px 0; background: var(--bg-light); min-height: 600px; }

        #result-card {
            max-width: 700px; margin: 0 auto 40px; background: white;
            padding: 40px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            display: none; border-left: 5px solid var(--primary-red);
            position: relative;
        }
        .close-card {
            position: absolute; top: 15px; right: 20px;
            font-size: 24px; color: #94a3b8; cursor: pointer; transition: 0.2s;
        }
        .close-card:hover { color: var(--primary-red); }

        .carrier-title { font-size: 32px; margin-bottom: 20px; color: var(--dark-blue); }
        .carrier-detail { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; font-size: 20px; }
        .carrier-detail i { color: var(--primary-red); width: 25px; font-size: 20px; }
        .carrier-detail a { color: var(--dark-blue); text-decoration: none; font-weight: 600; }
        .carrier-detail a:hover { text-decoration: underline; }
        .carrier-label { font-size: 13px; font-weight: 800; text-transform: uppercase; color: #64748b; display: block; margin-bottom: 2px; }
        .email-link { font-size: 16px; color: #475569 !important; font-weight: 500 !important; display: block; margin-top: 4px; }
        .carrier-note { font-size: 15px; color: #64748b; font-style: italic; margin-top: 5px; display: block; }

        .manual-browse { max-width: 1100px; margin: 0 auto; }
        .manual-browse h2 { margin-bottom: 20px; font-size: 36px; text-align: center; border-bottom: 4px solid var(--primary-red); display: inline-block; padding-bottom: 10px; }
        .section-title-wrap { text-align: center; margin-bottom: 10px; }

        .emergency-accordion {
            max-width: 900px;
            margin: 0 auto 40px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        .emergency-accordion .accordion-header {
            background: var(--dark-blue);
            color: white;
            padding: 15px 25px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
            font-size: 20px;
            transition: background 0.3s;
        }
        .emergency-accordion .accordion-header:hover { background: #1e293b; }
        .emergency-accordion .accordion-header i { transition: transform 0.3s; }
        .emergency-accordion .accordion-header.active i { transform: rotate(180deg); }

        .emergency-accordion .accordion-content {
            padding: 0 25px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease-out, padding 0.4s ease;
            background: white;
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.6;
        }
        .emergency-accordion .accordion-content.open {
            padding: 25px;
            max-height: 800px;
        }

        .checklist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
            margin-top: 20px;
            text-align: left;
        }
        .checklist-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #f8fafc;
            padding: 12px;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
            font-weight: 600;
        }
        .checklist-item i { color: #10b981; }

        .instruction-text {
            display: block;
            text-align: center;
            font-size: 14px;
            color: #64748b;
            margin-bottom: 10px;
            font-style: italic;
        }

        .office-hours-notice {
            background: #eef2ff;
            border: 1px solid #c7d2fe;
            padding: 15px;
            border-radius: 8px;
            max-width: 900px;
            margin: 0 auto 30px;
            text-align: center;
            font-size: 16px;
            color: #3730a3;
        }

        @media (max-width: 768px) {
            .claims-hero h1 { font-size: 32px; }
            .claims-hero p { font-size: 16px; }
            .claims-hero { padding: 20px 0; }
            .claims-main { padding: 30px 0; }
            .carrier-detail { font-size: 16px; }
            .carrier-title { font-size: 26px; }
            #result-card { padding: 25px; }
            .manual-browse h2 { font-size: 26px; }
            .search-container input { padding: 16px 40px 16px 20px; font-size: 16px; }
            .emergency-accordion .accordion-header { font-size: 16px; padding: 12px 18px; }
            .office-hours-notice { font-size: 14px; padding: 12px; }
        }
        @media (max-width: 480px) {
            .claims-hero h1 { font-size: 26px; }
            .checklist-grid { grid-template-columns: 1fr; }
        }
    </style>

    <script is:inline>
        const allCarriers = [
            { name: "AIG", numbers: [{label: "Claims", phone: "888-760-9195", email: "irwinsiegelclaims@aig.com"}] },
            { name: "American Collectors", numbers: [{label: "Claims", phone: "800-360-2277", email: "info@americancollectors.com"}] },
            { name: "AmTrust", numbers: [{label: "Claims", phone: "877-528-7878", email: "glclaimreport@amtrustgroup.com"}] },
            { name: "Andover", numbers: [{label: "Claims", phone: "800-225-0770", email: "welcome@andovercos.com"}] },
            { name: "AON Edge EZ Flood", numbers: [{label: "Claims", phone: "844-325-3004", email: "aonedgeclaims@us.crawco.com"}] },
            { name: "Arch Insurance Company", numbers: [{label: "Business Claims", phone: "800-822-3747", email: "claims@archinsurance.com"}] },
            { name: "Assurant FloodPort", numbers: [{label: "Flood Claims", phone: "1-800-423-4403", email: "myfloodclaim@assurant.com", note: "Select option 2 to report new"}] },
            { name: "Attune", numbers: [{label: "Claims", phone: "888-530-4650", email: "hello@attuneinsurance.com"}] },
            { name: "Chubb", numbers: [{label: "Claims", phone: "800-252-4670", email: "claims@gotoservice.chubb.com"}] },
            { name: "CNA", numbers: [{label: "Claims", phone: "877-262-2727", email: "gapclaims@cnanational.com"}] },
            { name: "Essentia", numbers: [{label: "Claims", phone: "877-922-9701", email: "claims@hagerty.com"}] },
            { name: "Farmers", numbers: [{label: "Claims", phone: "800-435-7764", email: "life.claims@farmersinsurance.com"}] },
            { name: "Foremost", numbers: [{label: "Claims", phone: "800-527-3907", email: "myclaim@foremost.com"}] },
            { name: "Global Marine", numbers: [{label: "Claims", phone: "800-748-0224", email: "claims@globalmarineinsurance.com"}] },
            { name: "GNY", numbers: [{label: "Claims", phone: "516-869-8666", email: "NYCompClaims@gny.com"}] },
            { name: "Grundy", numbers: [{label: "Claims", phone: "800-765-9749", email: "collectorvehicle@grundy.com"}] },
            { name: "Hagerty", numbers: [{label: "Claims", phone: "800-922-4050", email: "claims@hagerty.com"}] },
            { name: "Hartford", numbers: [{label: "Personal Claims", phone: "800-243-5860", email: "Agency.services@thehartford.com"}, {label: "Business Claims", phone: "800-243-5860", email: "Agency.services@thehartford.com"}] },
            { name: "HCC Midwest", numbers: [{label: "Claims", phone: "800-225-6561", email: "claims@midwestfamily.com"}] },
            { name: "Hiscox", numbers: [{label: "Claims", phone: "888-202-3007", email: "reportaclaim@hiscox.com"}] },
            { name: "JC Taylor", numbers: [{label: "Claims", phone: "800-345-8290", email: "support@jctaylor.com"}] },
            { name: "Jewelers Mutual (JIBNA)", numbers: [{label: "Claims", phone: "888-884-2424", email: "claims@jminsure.com"}] },
            { name: "Kingstone", numbers: [{label: "Claims", phone: "855-394-0704", email: "claims@kingstoneinsurance.com"}] },
            { name: "Lancer", numbers: [{label: "Claims", phone: "800-444-5150", email: "claims@lancerinsurance.com"}] },
            { name: "Lloyds of London", numbers: [{label: "Claims", phone: "800-444-5150", email: "claims@lancerinsurance.com"}] },
            { name: "McNeil", numbers: [{label: "Claims", phone: "800-822-3747", email: "claims@mcneilandcompany.com"}] },
            { name: "Merchants", numbers: [
                {label: "Personal Claims", phone: "800-952-5246", email: "claims@merchantsgroup.com"},
                {label: "Business Claims", phone: "800-722-6523", email: "claims@merchantsgroup.com"},
                {label: "Evening Claims", phone: "888-644-6680"},
                {label: "Towing", phone: "866-328-5771"}
            ]},
            { name: "Narragansett Bay Insurance", numbers: [{label: "Claims", phone: "800-343-3375", email: "claims@nbic.com"}] },
            { name: "National General", numbers: [
                {label: "Claims", phone: "800-325-1088", email: "nationalgeneral@torrentcorp.com"},
                {label: "Auto Claims", phone: "800-325-1088"},
                {label: "Flood Claims", phone: "800-325-1088", email: "nationalgeneral@torrentcorp.com"}
            ]},
            { name: "Nationwide", numbers: [{label: "Claims", phone: "800-320-7586", email: "enewloss@nationwide.com"}] },
            { name: "NatGen Premier", numbers: [{label: "Claims", phone: "844-287-2236", email: "claims@natgenpremier.com"}] },
            { name: "Neptune Flood", numbers: [{label: "Claims", phone: "727-202-4815", email: "claims@neptuneflood.com"}] },
            { name: "Ocean Harbor / Complex Coverage", numbers: [{label: "Claims", phone: "855-585-0500", email: "claims@oceanharbor-ins.com"}] },
            { name: "Personal Umbrella", numbers: [{label: "Claims", phone: "800-564-1799", email: "claims@personalumbrella.com"}] },
            { name: "Plymouth Rock", numbers: [{label: "Claims", phone: "844-208-1235", email: "claims@plymouthrock.com"}] },
            { name: "Progressive", numbers: [{label: "Claims", phone: "800-776-4737", email: "claims@progressive.com"}] },
            { name: "Safeco", numbers: [{label: "Claims", phone: "800-332-3226", email: "claims@safeco.com"}] },
            { name: "Sage Sure", numbers: [{label: "Claims", phone: "800-481-0696", email: "claims@sagesure.com"}] },
            { name: "Scottsdale", numbers: [{label: "Claims", phone: "800-423-7675", email: "newclaim@scottsdaleins.com"}] },
            { name: "Seneca", numbers: [{label: "Claims", phone: "800-539-0657", email: "claims@senecainsurance.com"}] },
            { name: "Shore One", numbers: [{label: "Claims", phone: "888-513-1314", email: "claims@shoreoneinsurance.com"}] },
            { name: "Sutton", numbers: [{label: "Claims", phone: "800-461-3292", email: "claims@suttonspecialty.com"}] },
            { name: "Travelers", numbers: [
                {label: "Personal Claims", phone: "800-252-4633", email: "claims@travelers.com"},
                {label: "Business Claims", phone: "800-238-6225", email: "claims@travelers.com"},
                {label: "Boat Claims", phone: "800-952-8699", email: "claims@travelers.com"}
            ]},
            { name: "USLI", numbers: [{label: "Claims", phone: "888-523-5545", email: "newlosses@usli.com"}] },
            { name: "Utica", numbers: [
                {label: "Business Claims", phone: "800-766-1914", email: "claims@uticanational.com"},
                {label: "Utica First Claims", phone: "800-456-4556", email: "claims@uticafirst.com"},
                {label: "Personal Claims", phone: "800-216-1420", email: "claims@uticanational.com"}
            ]},
            { name: "Wright Flood", numbers: [{label: "Claims", phone: "800-725-9472", email: "floodclaims@wrightflood.com"}] },
            { name: "Zurich", numbers: [{label: "Claims", phone: "877-397-2329", email: "usz.newclaims@zurichna.com"}] }
        ].sort((a, b) => a.name.localeCompare(b.name));

        function toggleAccordion() {
            const header = document.querySelector('.accordion-header');
            const content = document.getElementById('accordionContent');
            header.classList.toggle('active');
            content.classList.toggle('open');
        }

        const input = document.getElementById('carrierSearch');
        const list = document.getElementById('autocompleteList');
        const clearBtn = document.getElementById('clearSearch');
        const resultCard = document.getElementById('result-card');
        const detailsContainer = document.getElementById('details-container');
        const grid = document.getElementById('mainGrid');

        allCarriers.forEach(c => {
            const btn = document.createElement('div');
            btn.className = 'carrier-btn';
            btn.innerText = c.name;
            btn.onclick = () => selectCarrier(c.name);
            grid.appendChild(btn);
        });

        input.addEventListener('input', function() {
            const val = this.value.trim().toLowerCase();
            list.innerHTML = '';
            clearBtn.style.display = val ? 'block' : 'none';

            if (!val) {
                list.style.display = 'none';
                return;
            }

            const matches = allCarriers.filter(c => c.name.toLowerCase().includes(val));

            matches.sort((a, b) => {
                const aStartsWith = a.name.toLowerCase().startsWith(val);
                const bStartsWith = b.name.toLowerCase().startsWith(val);
                if (aStartsWith && !bStartsWith) return -1;
                if (!aStartsWith && bStartsWith) return 1;
                return a.name.localeCompare(b.name);
            });

            if (matches.length > 0) {
                matches.forEach(m => {
                    const div = document.createElement('div');
                    div.className = 'autocomplete-item';
                    div.innerHTML = `<strong>${m.name}</strong>`;
                    div.addEventListener('mousedown', function(e) {
                        e.preventDefault();
                        input.value = m.name;
                        selectCarrier(m.name);
                        list.style.display = 'none';
                    });
                    list.appendChild(div);
                });
                list.style.display = 'block';
            } else {
                list.style.display = 'none';
            }
        });

        function closeResultCard() {
            resultCard.style.display = 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        clearBtn.addEventListener('click', function(e) {
            e.preventDefault();
            input.value = '';
            list.style.display = 'none';
            clearBtn.style.display = 'none';
            resultCard.style.display = 'none';
            input.focus();
        });

        function selectCarrier(name) {
            const carrier = allCarriers.find(c => c.name === name);
            if (!carrier) return;

            document.getElementById('res-name').innerText = carrier.name;
            detailsContainer.innerHTML = '';

            carrier.numbers.forEach(n => {
                const row = document.createElement('div');
                row.className = 'carrier-detail';
                const lowLabel = n.label.toLowerCase();
                const iconClass = lowLabel.includes('business') ? 'fa-briefcase' :
                                   lowLabel.includes('towing') ? 'fa-truck-pickup' :
                                   lowLabel.includes('auto') ? 'fa-car' :
                                   lowLabel.includes('flood') ? 'fa-house-flood-water' : 'fa-phone';

                row.innerHTML = `
                    <i class="fa-solid ${iconClass}"></i>
                    <div>
                        <span class="carrier-label">${n.label}</span>
                        <a href="tel:${n.phone.replace(/[^0-9]/g, '')}">${n.phone}</a>
                        ${n.email ? `<a href="mailto:${n.email}" class="email-link"><i class="fa-regular fa-envelope" style="font-size: 14px; margin-right: 5px; color: #64748b;"></i>${n.email}</a>` : ''}
                        ${n.note ? `<span class="carrier-note">${n.note}</span>` : ''}
                    </div>`;
                detailsContainer.appendChild(row);
            });

            resultCard.style.display = 'block';
            resultCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        document.addEventListener('click', (e) => {
            if (e.target !== input) {
                list.style.display = 'none';
            }
        });
    </script>

</BaseLayout>
